generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Better Auth Tables (Admin Dashboard Auth)
// Prefixed with "admin_" to not conflict with main site
// ============================================

model AdminUser {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  role          String    @default("admin")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      AdminSession[]
  accounts      AdminAccount[]

  @@map("admin_user")
}

model AdminSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("admin_session")
}

model AdminAccount {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?   @db.Text
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("admin_account")
}

model AdminVerification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("admin_verification")
}

// ============================================
// Main Site Tables (Read-only from Admin)
// MUST match apps/web/prisma/schema.prisma exactly
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  embeddings    ToolEmbedding[]
  bugReports    BugReport[]
  companies     Company[]
  jobs          Job[]
  submissions   Submission[]
  projects      Project[]
  uploads       Upload[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?   @db.Text
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model ToolEmbedding {
  id        String              @id @default(cuid())
  toolSlug  String
  summary   String?
  embedding Unsupported("vector")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([toolSlug])
}

model BugReport {
  id          String   @id @default(cuid())
  tool        String
  title       String
  description String   @db.Text
  version     String?
  os          String?
  status      String   @default("open")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([tool])
  @@index([userId])
}

// ============================================================================
// SHARED TABLES - Synced from pcbtools main site
// These are READ-ONLY in admin, main site owns these tables
// ============================================================================

model Company {
  id          String   @id @default(cuid())
  name        String
  logo        String?
  location    String?
  bio         String?  @db.Text
  website     String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs        Job[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Job {
  id             String       @id @default(cuid())
  title          String
  location       String
  workplaceType  String       @default("onsite")
  experience     Int?
  description    String?      @db.Text
  applyUrl       String?
  tier           String       @default("standard")
  status         String       @default("active")
  companyId      String
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([companyId])
  @@index([userId])
  @@index([status])
}

// === Submission Pipeline ===

enum ContentType {
  AI_TOOL
  RESOURCE
  NEWS
  TOOL
  BOARD
  RULE
  STACKUP
  LIBRARY
}

enum SubmissionStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

model Submission {
  id               String           @id @default(uuid())
  title            String
  slug             String           @unique
  contentType      ContentType
  status           SubmissionStatus @default(PENDING_REVIEW)
  shortDescription String?
  description      String?          @db.Text
  websiteUrl       String?
  githubUrl        String?
  logoUrl          String?
  coverImageUrl    String?
  tags             String[]
  viewCount        Int              @default(0)

  authorId         String
  author           User             @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  publishedAt      DateTime?

  metadata         SubmissionMeta[]

  @@index([contentType, status])
  @@index([authorId])
  @@index([contentType, publishedAt])
}

model SubmissionMeta {
  id           String     @id @default(uuid())
  submissionId String
  key          String
  value        String     @db.Text

  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, key])
}

// === News Aggregator ===

model NewsArticle {
  id          String   @id @default(cuid())
  title       String
  url         String   @unique
  source      String
  category    String   @default("PCB & Electronics")
  image       String?
  snippet     String?  @db.Text
  tags        String[]
  publishedAt DateTime
  createdAt   DateTime @default(now())

  @@index([source])
  @@index([category])
  @@index([publishedAt])
}

// === Saved Projects ===

model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String   @db.VarChar(100)
  data      Json     @default("{\"version\":1,\"calculations\":[]}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("project")
}

// === Gerber Upload & Analysis ===

enum UploadStatus {
  UPLOADING
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
}

model Upload {
  id           String        @id @default(cuid())
  userId       String
  filename     String
  originalName String
  fileSize     Int
  mimeType     String
  storageKey   String        @unique
  publicUrl    String?
  status       UploadStatus  @default(UPLOADING)
  metadata     Json?         @default("{}")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis     UploadAnalysis?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model UploadAnalysis {
  id             String   @id @default(cuid())
  uploadId       String   @unique
  layerCount     Int      @default(0)
  boardWidth     Float?
  boardHeight    Float?
  drillHoles     Int      @default(0)
  copperLayers   Int      @default(0)
  surfaceFinish  String?
  parsedData     Json?
  drcViolations  Json?    @default("[]")
  costEstimate   Json?
  createdAt      DateTime @default(now())

  upload         Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
}
